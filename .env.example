# Google Analytics 4 Measurement ID (looks like G-XXXXXXXXXX).
# Set this in Vercel for all environments where you want tracking enabled.
# Leave empty in local dev to avoid polluting analytics with dev traffic.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console ownership verification token (the content value of the
# meta tag GSC gives you under Settings → Ownership verification → HTML tag).
# Leave empty to omit the tag.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Required for the contact form to deliver enquiries. Add a Resend API key in
# Vercel under Project Settings -> Environment Variables.
RESEND_API_KEY=
